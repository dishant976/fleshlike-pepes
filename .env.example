# Fleshlike Pepes API — Environment Variables
# Copy this to .env and fill in your values

# Your Ethereum RPC URL (free options below — pick one):
# - https://eth.llamarpc.com          (LlamaNodes, free, no key needed)
# - https://rpc.ankr.com/eth          (Ankr, free tier)
# - https://mainnet.infura.io/v3/YOUR_KEY  (Infura, free tier)
# - https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY  (Alchemy, free tier)
ETH_RPC_URL=https://eth.llamarpc.com

# Port to run on (default: 3000)
PORT=3000
